# ─────────────────────────────────────────────
#  Kungbi PR Reviewer Bot — Environment Variables
# ─────────────────────────────────────────────

# GitHub Personal Access Token (optional if using `gh auth login`)
# Needs: repo, read:org scopes
GH_TOKEN=ghp_your_token_here

# GitHub username to watch for review requests
GH_REVIEWER=your-github-username

# Secret used to validate GitHub webhook signatures (HMAC-SHA256)
WEBHOOK_SECRET=your_github_webhook_secret_here

# Discord Incoming Webhook URL to post notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url-here

# Bot name shown in logs and Discord messages
BOT_NAME=kungbi-spider

# Bot avatar URL shown in Discord messages
BOT_AVATAR_URL=https://github.com/your-avatar.png

# Log verbosity: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# How often (seconds) the poller checks GitHub for new PRs
POLL_INTERVAL=5

# ── Repo-clone based PR review ──────────────────────────────────────────────
# Clone the PR branch locally so the subagent uses cat/grep/find instead of gh api.
# Set to "false" or "0" to disable and fall back to gh-based review.
PR_CLONE_ENABLED=true

# Shallow clone depth (number of commits). Increase if merge-base failures occur.
PR_CLONE_DEPTH=200

# Timeout in milliseconds for the entire clone operation.
PR_CLONE_TIMEOUT_MS=90000
