# ─────────────────────────────────────────────
#  Kungbi PR Reviewer Bot — Environment Variables
# ─────────────────────────────────────────────

# GitHub Personal Access Token (optional if using `gh auth login`)
# Needs: repo, read:org scopes
GH_TOKEN=ghp_your_token_here

# GitHub username to watch for review requests
GH_REVIEWER=your-github-username

# Secret used to validate GitHub webhook signatures (HMAC-SHA256)
WEBHOOK_SECRET=your_github_webhook_secret_here

# Discord Incoming Webhook URL to post notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url-here

# Discord Bot Token for receiving manual review commands (optional)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID to watch for manual review triggers (optional)
DISCORD_CHANNEL_ID=your_channel_id_here

# Bot name shown in logs and Discord messages
BOT_NAME=kungbi-spider

# Bot avatar URL shown in Discord messages
BOT_AVATAR_URL=https://github.com/your-avatar.png

# Log verbosity: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# How often (seconds) the poller checks GitHub for new PRs
POLL_INTERVAL=5

# ── Repo-clone based PR review ──────────────────────────────────────────────
# Clone the PR branch locally so the subagent uses cat/grep/find instead of gh api.
# Set to "false" or "0" to disable and fall back to gh-based review.
PR_CLONE_ENABLED=true

# Shallow clone depth (number of commits). Increase if merge-base failures occur.
PR_CLONE_DEPTH=200

# Timeout in milliseconds for the entire clone operation.
PR_CLONE_TIMEOUT_MS=90000

# Per-review timeout in minutes. The review subagent is SIGTERM'd after this,
# then SIGKILL'd 30s later. Increase if reviews on large PRs keep timing out.
REVIEW_TIMEOUT_MIN=50

# ── Review agent ────────────────────────────────────────────────────────────
# Which CLI coding agent to spawn for the review: "claude" (default) or "opencode".
# Both must be installed and authenticated on the host. Each agent reads its OWN
# model var below, so flipping REVIEW_AGENT alone is safe — no need to touch models.
REVIEW_AGENT=claude

# Model for claude (short alias, e.g. "opus" or "sonnet"). Used only when
# REVIEW_AGENT=claude. Defaults to "opus" if unset. Ignored by opencode.
REVIEW_MODEL=opus

# Model for opencode in "provider/model" form. Used only when REVIEW_AGENT=opencode.
# Leave unset to use opencode's own configured default model.
# NOTE: on this host only "google/*" models were verified working; the openai
# (codex) default was failing token refresh. Pin a model you know is authed.
#   e.g. google/gemini-2.5-flash  |  openai/gpt-5.2-codex
OPENCODE_MODEL=google/gemini-2.5-flash

# Max PRs reviewed in parallel (caps memory from concurrent subagents).
REVIEW_CONCURRENCY=3
