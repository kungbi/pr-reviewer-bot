# ══════════════════════════════════════════════════════════════════════════════
#  Kungbi PR Reviewer Bot — Environment Variables
#
#  Copy this file to `.env` and fill in your values. Only DISCORD_WEBHOOK_URL is
#  required; every other variable has a sensible default (shown as its value here).
# ══════════════════════════════════════════════════════════════════════════════


# ── GitHub ────────────────────────────────────────────────────────────────────

# Personal Access Token. Optional if you've run `gh auth login`.
# Scopes needed: repo, read:org
GH_TOKEN=ghp_your_token_here

# GitHub username whose review requests the bot watches for.
GH_REVIEWER=your-github-username

# Secret for validating GitHub webhook signatures (HMAC-SHA256).
# Unused in polling mode; kept for webhook compatibility.
WEBHOOK_SECRET=your_github_webhook_secret_here


# ── Discord ───────────────────────────────────────────────────────────────────

# Incoming webhook URL for posting review notifications.          [REQUIRED]
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url-here

# Bot token + channel ID for receiving manual review commands.    [optional]
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here


# ── Bot identity ──────────────────────────────────────────────────────────────

# Name and avatar shown in logs and Discord messages.
BOT_NAME=kungbi-spider
BOT_AVATAR_URL=https://github.com/your-avatar.png


# ── Server & runtime ──────────────────────────────────────────────────────────

# HTTP server port.
PORT=3000

# Log verbosity: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# How often (in minutes) the poller checks GitHub for new review requests.
POLL_INTERVAL_MIN=5

# Days to keep completed PR entries in the state file before pruning.
STATE_RETENTION_DAYS=30


# ── PR review · repo clone ────────────────────────────────────────────────────

# Clone the PR branch locally so the agent uses cat/grep/find instead of gh api.
# Set to "false" or "0" to disable and fall back to gh-based review.
PR_CLONE_ENABLED=true

# Shallow clone depth (number of commits). Increase if merge-base failures occur.
PR_CLONE_DEPTH=200

# Timeout (ms) for the entire clone operation.
PR_CLONE_TIMEOUT_MS=90000


# ── PR review · agent ─────────────────────────────────────────────────────────

# Which CLI coding agent to spawn for the review:
#     claude  (default)  |  opencode  |  codex
# The chosen agent must be installed and authenticated on the host. Each agent
# reads its OWN model var below, so flipping REVIEW_AGENT alone is safe — the
# other agents' model vars are ignored.
REVIEW_AGENT=claude

# claude — short alias (e.g. "opus", "sonnet"). Default: opus.
REVIEW_MODEL=opus

# opencode — "provider/model" form (e.g. "google/gemini-2.5-flash").
# Leave unset to use opencode's own configured default.
# NOTE: opencode's OpenAI models are blocked on a ChatGPT-account OAuth host —
# use REVIEW_AGENT=codex for OpenAI instead. (google/* models worked here.)
OPENCODE_MODEL=google/gemini-2.5-flash

# codex — bare model name (e.g. "gpt-5.5", "gpt-5.2-codex", "gpt-5.1-codex-max").
# Leave unset to use codex's own default (~/.codex/config.toml).
# Uses the official OpenAI Codex CLI, which works with ChatGPT-account OAuth.
CODEX_MODEL=gpt-5.2-codex

# Per-review timeout (minutes). The agent is SIGTERM'd after this, then SIGKILL'd
# 30s later. Increase if reviews on large PRs keep timing out.
REVIEW_TIMEOUT_MIN=50

# Max PRs reviewed in parallel (caps memory from concurrent agents).
REVIEW_CONCURRENCY=3
